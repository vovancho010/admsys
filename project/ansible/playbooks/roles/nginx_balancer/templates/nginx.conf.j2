# {{ ansible_managed }}
# Nginx Load Balancer Configuration
# Managed by Ansible

upstream backend {
    # Балансировка методом {{ load_balancing_method }}
    {% if load_balancing_method == 'least_conn' %}
    least_conn;
    {% elif load_balancing_method == 'ip_hash' %}
    ip_hash;
    {% endif %}
    
    # Список веб-серверов
    {% for server in web_servers %}
    server {{ server }}:{{ web_server_port }};
    {% endfor %}
}

server {
    listen {{ balancer_listen_port }};
    server_name {{ server_name }};

    # Логи
    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    # Настройки проксирования
    location / {
        proxy_pass http://backend;
        
        # Передаём реальные IP и заголовки
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Таймауты
        proxy_connect_timeout {{ proxy_connect_timeout }};
        proxy_send_timeout {{ proxy_send_timeout }};
        proxy_read_timeout {{ proxy_read_timeout }};
        
        # Буферизация
        proxy_buffer_size {{ proxy_buffer_size }};
        proxy_buffers {{ proxy_buffers }};
    }
    
     Страница статуса (опционально, закомментировано по умолчанию)
     location /nginx_status {
         stub_status on;
         allow 192.168.3.0/24;
         deny all;
     }
}