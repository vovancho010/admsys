<?php
// {{ ansible_managed }}
// PHP Information Page

echo "<h1>PHP Information</h1>";
echo "<p><strong>Server Name:</strong> " . gethostname() . "</p>";
echo "<p><strong>Server IP:</strong> " . $_SERVER['SERVER_ADDR'] . "</p>";

// Test database connection
$db_host = "{{ db_host }}";
$db_port = "{{ db_port }}";
$db_name = "{{ db_name }}";
$db_user = "{{ db_user }}";
$db_password = "{{ db_password }}";

try {
    $pdo = new PDO("pgsql:host=$db_host;port=$db_port;dbname=$db_name", $db_user, $db_password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    echo "<p style='color:green'>✅ Database connection: SUCCESS</p>";
    
    // Show PostgreSQL version
    $stmt = $pdo->query("SELECT version()");
    $version = $stmt->fetch();
    echo "<p><strong>PostgreSQL Version:</strong> " . $version[0] . "</p>";
    
} catch (PDOException $e) {
    echo "<p style='color:red'>❌ Database connection: FAILED</p>";
    echo "<p>Error: " . $e->getMessage() . "</p>";
}

phpinfo();
?>