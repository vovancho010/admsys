<!DOCTYPE html>
<html>
<head>
    <title>Welcome to {{ ansible_hostname }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 50px;
            text-align: center;
        }
        .container {
            border: 2px solid #4CAF50;
            border-radius: 10px;
            padding: 20px;
            max-width: 600px;
            margin: 0 auto;
        }
        h1 { color: #4CAF50; }
        .server-info {
            background: #f0f0f0;
            padding: 10px;
            border-radius: 5px;
            margin: 20px 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🚀 Web Server</h1>
        <div class="server-info">
            <p><strong>Server Name:</strong> {{ ansible_hostname }}</p>
            <p><strong>IP Address:</strong> {{ ansible_default_ipv4.address }}</p>
            <p><strong>Web Server:</strong> {{ web_server }}</p>
        </div>
        <p>This request was processed by <strong>{{ ansible_hostname }}</strong></p>
        <hr>
        <p><a href="/info.php">PHP Info</a></p>
    </div>
</body>
</html>