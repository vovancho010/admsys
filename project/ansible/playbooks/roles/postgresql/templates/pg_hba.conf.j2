# {{ ansible_managed }}
# PostgreSQL Client Authentication Configuration File (pg_hba.conf)

# TYPE  DATABASE        USER            ADDRESS                 METHOD

# Local connections (unix socket)
local   all             postgres                                peer
local   all             all                                     peer

# IPv4 local connections
host    all             all             127.0.0.1/32            md5

# IPv6 local connections
host    all             all             ::1/128                 md5

# Allow connections from our private network (Vagrant)
{% for network in postgresql_allow_networks %}
host    {{ postgresql_database }}    {{ postgresql_user }}    {{ network }}    md5
{% endfor %}

# Default deny for other networks
host    all             all             0.0.0.0/0               reject